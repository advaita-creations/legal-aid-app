# Auth mode: 'django' (local dev, session auth) or 'supabase' (production, JWT)
VITE_AUTH_MODE=django

# Supabase Configuration (only needed when VITE_AUTH_MODE=supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend API
VITE_API_BASE_URL=http://localhost:8000/api
